# Normalize line endings across platforms.
* text=auto eol=lf

# Scripts and configs that MUST stay LF (run inside Linux containers).
*.sh text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
.env.example text eol=lf

# Windows-only scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat these as binary (no diff/merge munging).
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
