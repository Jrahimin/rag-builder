# Copy to runtime.env, chmod 600, and populate from the deployment secrets manager.
# Never commit runtime.env, tls.crt, or tls.key.
APE_APP__ENV=production
APE_APP__DEBUG=false
APE_APP__VERSION=0.9.0
APE_RUNTIME__PROFILE=hosted_openai
APE_LOGGING__RENDER_JSON=true
APE_CORS__ALLOW_ORIGINS=https://rag-builder.example
APE_AUTH__ENABLED=true
APE_AUTH__ADMIN_API_KEY=replace-with-32-plus-random-bytes
APE_AUTH__KEY_PEPPER=replace-with-32-plus-random-bytes
APE_WEBHOOKS__ENABLED=true
APE_WEBHOOKS__DISPATCHER_ENABLED=true
APE_WEBHOOKS__SIGNING_KEY=replace-with-32-plus-random-bytes
APE_DATABASE__HOST=postgres
APE_DATABASE__PORT=5432
APE_DATABASE__USER=ape
APE_DATABASE__PASSWORD=replace-database-password
APE_DATABASE__NAME=ape
POSTGRES_USER=ape
POSTGRES_PASSWORD=replace-database-password
POSTGRES_DB=ape
APE_REDIS__HOST=redis
APE_REDIS__PORT=6379
APE_REDIS__PASSWORD=replace-redis-password
REDIS_PASSWORD=replace-redis-password
APE_STORAGE__BACKEND=minio
APE_MINIO__ENDPOINT=minio:9000
APE_MINIO__ACCESS_KEY=replace-minio-access-key
APE_MINIO__SECRET_KEY=replace-minio-secret-key
APE_MINIO__BUCKET=ape-artifacts
MINIO_ROOT_USER=replace-minio-access-key
MINIO_ROOT_PASSWORD=replace-minio-secret-key
MINIO_BUCKET=ape-artifacts
APE_MALWARE_SCAN__BACKEND=clamav
APE_MALWARE_SCAN__HOST=clamav
APE_MALWARE_SCAN__PORT=3310
APE_JOBS__BACKEND=taskiq
APE_EMBEDDING__BACKEND=openai
APE_EMBEDDING__MODEL=text-embedding-3-small
APE_EMBEDDING__DIMENSIONS=1536
APE_EMBEDDING__OPENAI_API_KEY=replace-provider-secret
APE_LLM__BACKEND=openai
APE_LLM__MODEL=gpt-4o-mini
APE_LLM__OPENAI_API_KEY=replace-provider-secret
APE_RETRIEVAL__STRATEGY=hybrid
