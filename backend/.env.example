# ===========================================================================
# AI Platform Engine (APE) - backend local environment template.
#
# Copy to `.env` and adjust as needed (run from the backend/ directory):
#     cp .env.example .env            (macOS/Linux)
#     Copy-Item .env.example .env     (Windows PowerShell)
#
# Consumed by the FastAPI application (Pydantic Settings). All keys use the
# APE_ prefix with double-underscore nesting, e.g. APE_DATABASE__HOST.
#
# Hosts are localhost — use this file when running the API in a local venv
# against infrastructure started via docker compose from the repo root.
# For the full Docker stack, use the root `.env.docker` file instead.
# ===========================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APE_APP__NAME=AI Platform Engine
# One of: development | testing | production
APE_APP__ENV=development
APE_APP__DEBUG=true
APE_APP__VERSION=0.1.0
APE_APP__API_V1_PREFIX=/api/v1

# ----------------------------------------------------------------------------
# Server (uvicorn) — used by `python -m app` from backend/
# For explicit CLI flags instead, run: uvicorn app.main:app --reload --host 0.0.0.0 --port 8088
# ----------------------------------------------------------------------------
APE_SERVER__HOST=0.0.0.0
APE_SERVER__PORT=8088
APE_SERVER__RELOAD=true
APE_SERVER__WORKERS=1

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
APE_LOGGING__LEVEL=INFO
# true  -> JSON logs (production / log aggregation)
# false -> colorized console logs (local development)
APE_LOGGING__RENDER_JSON=false

# ----------------------------------------------------------------------------
# CORS (comma-separated, or "*" for all)
# ----------------------------------------------------------------------------
APE_CORS__ALLOW_ORIGINS=*
APE_CORS__ALLOW_CREDENTIALS=true

# ----------------------------------------------------------------------------
# PostgreSQL (local venv → localhost; docker stack uses service hostnames)
# ----------------------------------------------------------------------------
APE_DATABASE__HOST=localhost
APE_DATABASE__PORT=5432
APE_DATABASE__USER=ape
APE_DATABASE__PASSWORD=ape
APE_DATABASE__NAME=ape
APE_DATABASE__ECHO=false
APE_DATABASE__POOL_SIZE=5
APE_DATABASE__MAX_OVERFLOW=10

# Integration tests (pytest) — use a disposable database only:
#   APE_DATABASE__NAME=ape_test
#   APE_TEST_DATABASE__NAME=ape_test
#   APE_TEST_DATABASE__ALLOW_MIGRATIONS=true

# ----------------------------------------------------------------------------
# Authentication (Organization API keys)
# ----------------------------------------------------------------------------
# Single on/off — when false, protected routes skip credential checks (dev/tests).
APE_AUTH__ENABLED=false
# APE_AUTH__ADMIN_API_KEY=ape_live_admin_change_me
# APE_AUTH__KEY_PEPPER=change_me_min_32_bytes_random_secret
APE_AUTH__VERIFY_CACHE_ENABLED=true
APE_AUTH__VERIFY_CACHE_TTL_SECONDS=60
APE_AUTH__VERIFY_CACHE_BACKEND=memory
APE_AUTH__RATE_LIMIT_ENABLED=false
APE_AUTH__RATE_LIMIT_REQUESTS=1000
APE_AUTH__RATE_LIMIT_WINDOW_SECONDS=60
APE_AUTH__RATE_LIMIT_FAIL_OPEN=true

# Production checklist:
#   APE_AUTH__ENABLED=true
#   APE_AUTH__ADMIN_API_KEY=<random, at least 32 bytes>
#   APE_AUTH__KEY_PEPPER=<random, at least 32 bytes>
#   APE_AUTH__VERIFY_CACHE_BACKEND=redis
#   APE_AUTH__RATE_LIMIT_ENABLED=true
#   APE_AUTH__RATE_LIMIT_FAIL_OPEN=false

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
APE_REDIS__HOST=localhost
APE_REDIS__PORT=6379
APE_REDIS__DB=0
# APE_REDIS__PASSWORD=

# ----------------------------------------------------------------------------
# Qdrant (vector database)
# ----------------------------------------------------------------------------
APE_QDRANT__HOST=localhost
APE_QDRANT__PORT=6333
APE_QDRANT__GRPC_PORT=6334
APE_QDRANT__PREFER_GRPC=false
APE_QDRANT__HTTPS=false
# APE_QDRANT__API_KEY=

# --- Object storage (document uploads) ---
# local = filesystem under LOCAL_ROOT; minio = S3-compatible (Docker stack)
APE_STORAGE__BACKEND=local
APE_STORAGE__LOCAL_ROOT=./storage

# ----------------------------------------------------------------------------
# Background jobs (Taskiq + Redis)
# ----------------------------------------------------------------------------
APE_JOBS__BACKEND=taskiq

# ----------------------------------------------------------------------------
# Knowledge ingestion limits
# ----------------------------------------------------------------------------
# Maximum upload size in bytes (default 50 MB); larger uploads return 413.
# APE_KNOWLEDGE__MAX_UPLOAD_BYTES=52428800

# ----------------------------------------------------------------------------
# PDF parsing quality and fallback
# ----------------------------------------------------------------------------
# Comma-separated text parser order for PDFs: pymupdf,pdfium
# APE_PARSING__PDF_TEXT_PARSERS=pymupdf,pdfium
# APE_PARSING__MIN_PAGE_QUALITY_SCORE=0.55
# APE_PARSING__MIN_DOCUMENT_SUCCESS_RATIO=0.2
# APE_PARSING__MIN_TEXT_CHARS=20

# ----------------------------------------------------------------------------
# Text chunking (knowledge ingestion)
# ----------------------------------------------------------------------------
# Strategy: auto | markdown | heading | structure | semantic | recursive_fallback
# Token limits are approximate because embedding models tokenize differently.
APE_CHUNKING__STRATEGY=auto
APE_CHUNKING__TARGET_TOKENS=250
APE_CHUNKING__MAX_TOKENS=400
APE_CHUNKING__MIN_TOKENS=50
APE_CHUNKING__OVERLAP_TOKENS=50
APE_CHUNKING__STRUCTURE_SCORE_THRESHOLD=0.55
APE_CHUNKING__LONG_BLOCK_TOKEN_THRESHOLD=600
APE_CHUNKING__SIMILARITY_DROP_THRESHOLD=0.35
APE_CHUNKING__TOKEN_COUNT_METHOD=unicode_property_v1
APE_CHUNKING__OCR_CONFIDENCE_THRESHOLD=0.5

# ----------------------------------------------------------------------------
# OCR (optional — install backend/requirements/ocr.txt when enabled)
# ----------------------------------------------------------------------------
APE_OCR__ENABLED=false
# Backend: noop | paddle
APE_OCR__BACKEND=noop
APE_OCR__LANG=en
# Per-document override: upload form field ocr_lang or reprocess?ocr_lang=<code>
# Bangla (bn) is NOT supported on PaddleOCR 3.7 — requests fail at worker init.
# See docs/features/multilingual_support.md#known-limitation-bangla-bengali-ocr
APE_OCR__USE_GPU=false
APE_OCR__MIN_TEXT_CHARS=20
APE_OCR__MIN_IMAGE_AREA_RATIO=0.08
APE_OCR__DPI=200
APE_OCR__MIN_PAGE_CONFIDENCE=0.3

# ----------------------------------------------------------------------------
# Embeddings (retrieval Phase 1)
# ----------------------------------------------------------------------------
# Backend: hash | ollama | openai | gemini
# (any OpenAI-compatible host works via the openai backend + OPENAI_BASE_URL)
APE_EMBEDDING__BACKEND=hash
APE_EMBEDDING__MODEL=nomic-embed-text
APE_EMBEDDING__DIMENSIONS=384
APE_EMBEDDING__BATCH_SIZE=32
APE_EMBEDDING__OLLAMA_BASE_URL=http://localhost:11434
# APE_EMBEDDING__OPENAI_API_KEY=
# APE_EMBEDDING__OPENAI_BASE_URL=https://api.openai.com
# APE_EMBEDDING__GEMINI_API_KEY=
# APE_EMBEDDING__GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ----------------------------------------------------------------------------
# Vector store (retrieval Phase 2)
# ----------------------------------------------------------------------------
# Backend: qdrant | memory (memory is for tests only)
APE_VECTOR_STORE__BACKEND=qdrant
APE_VECTOR_STORE__COLLECTION_NAME=ape_chunks

# ----------------------------------------------------------------------------
# Retrieval pipeline
# ----------------------------------------------------------------------------
APE_RETRIEVAL__AUTO_EMBED=true
APE_RETRIEVAL__AUTO_INDEX=true
APE_RETRIEVAL__DEFAULT_TOP_K=10
APE_RETRIEVAL__EMBEDDING_SET_VERSION=1
APE_RETRIEVAL__FILTERABLE_METADATA_KEYS=source,tags,ocr_confidence
# PostgreSQL FTS regconfig — use simple for multilingual corpora
APE_RETRIEVAL__FTS_REGCONFIG=simple
# Optional minimum OCR confidence for keyword retrieval (omit to disable)
# APE_RETRIEVAL__MIN_OCR_CONFIDENCE=0.5
# Production retrieval strategy: semantic | hybrid
APE_RETRIEVAL__STRATEGY=hybrid
APE_RETRIEVAL__SEMANTIC_CANDIDATE_TOP_K=50
APE_RETRIEVAL__KEYWORD_CANDIDATE_TOP_K=50
APE_RETRIEVAL__RRF_K=60
APE_RETRIEVAL__SEMANTIC_WEIGHT=1.0
APE_RETRIEVAL__KEYWORD_WEIGHT=1.0
APE_RETRIEVAL__RERANK_ENABLED=true
APE_RETRIEVAL__RERANK_TOP_N=20
# Reranker backend: noop | lexical
APE_RETRIEVAL__RERANKER_BACKEND=lexical

# ----------------------------------------------------------------------------
# LLM (conversations / Chat)
# ----------------------------------------------------------------------------
# Backend: echo | openai | openai_compatible | ollama | gemini
APE_LLM__BACKEND=echo
APE_LLM__MODEL=gpt-4o-mini
APE_LLM__TEMPERATURE=0.7
APE_LLM__MAX_TOKENS=2048
APE_LLM__REQUEST_TIMEOUT_SECONDS=120
APE_LLM__OLLAMA_BASE_URL=http://localhost:11434
# APE_LLM__OPENAI_API_KEY=
# APE_LLM__OPENAI_BASE_URL=https://api.openai.com
# APE_LLM__GEMINI_API_KEY=
# APE_LLM__GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ----------------------------------------------------------------------------
# Chat / RAG orchestration
# ----------------------------------------------------------------------------
APE_CHAT__RETRIEVAL_TOP_K=10
APE_CHAT__MAX_CONTEXT_CHUNKS=8
APE_CHAT__CONTEXT_CHAR_BUDGET=12000
APE_CHAT__MAX_HISTORY_MESSAGES=20
APE_CHAT__SYSTEM_PROMPT_VERSION=v1
APE_CHAT__INCLUDE_CITATIONS=true

# ----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ----------------------------------------------------------------------------
APE_MINIO__ENDPOINT=localhost:9000
APE_MINIO__ACCESS_KEY=minioadmin
APE_MINIO__SECRET_KEY=minioadmin
APE_MINIO__SECURE=false
APE_MINIO__BUCKET=ape-artifacts
