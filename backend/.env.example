# ===========================================================================
# AI Platform Engine (APE) - backend local environment template.
#
# Copy to `.env` and adjust as needed (run from the backend/ directory):
#     cp .env.example .env            (macOS/Linux)
#     Copy-Item .env.example .env     (Windows PowerShell)
#
# Consumed by the FastAPI application (Pydantic Settings). All keys use the
# APE_ prefix with double-underscore nesting, e.g. APE_DATABASE__HOST.
#
# Hosts are localhost — use this file when running the API in a local venv
# against infrastructure started via docker compose from the repo root.
# For the full Docker stack, use the root `.env.docker` file instead.
# ===========================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APE_APP__NAME=AI Platform Engine
# One of: development | testing | production
APE_APP__ENV=development
APE_APP__DEBUG=true
APE_APP__VERSION=0.1.0
APE_APP__API_V1_PREFIX=/api/v1

# ----------------------------------------------------------------------------
# Server (uvicorn) — used by `python -m app` from backend/
# For explicit CLI flags instead, run: uvicorn app.main:app --reload --host 0.0.0.0 --port 8088
# ----------------------------------------------------------------------------
APE_SERVER__HOST=0.0.0.0
APE_SERVER__PORT=8088
APE_SERVER__RELOAD=true
APE_SERVER__WORKERS=1

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
APE_LOGGING__LEVEL=INFO
# true  -> JSON logs (production / log aggregation)
# false -> colorized console logs (local development)
APE_LOGGING__RENDER_JSON=false

# ----------------------------------------------------------------------------
# CORS (comma-separated, or "*" for all)
# ----------------------------------------------------------------------------
APE_CORS__ALLOW_ORIGINS=*
APE_CORS__ALLOW_CREDENTIALS=true

# ----------------------------------------------------------------------------
# PostgreSQL (local venv → localhost; docker stack uses service hostnames)
# ----------------------------------------------------------------------------
APE_DATABASE__HOST=localhost
APE_DATABASE__PORT=5432
APE_DATABASE__USER=ape
APE_DATABASE__PASSWORD=ape
APE_DATABASE__NAME=ape
APE_DATABASE__ECHO=false
APE_DATABASE__POOL_SIZE=5
APE_DATABASE__MAX_OVERFLOW=10

# Integration tests (pytest) — use a disposable database only:
#   APE_DATABASE__NAME=ape_test
#   APE_TEST_DATABASE__NAME=ape_test
#   APE_TEST_DATABASE__ALLOW_MIGRATIONS=true

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
APE_REDIS__HOST=localhost
APE_REDIS__PORT=6379
APE_REDIS__DB=0
# APE_REDIS__PASSWORD=

# ----------------------------------------------------------------------------
# Qdrant (vector database)
# ----------------------------------------------------------------------------
APE_QDRANT__HOST=localhost
APE_QDRANT__PORT=6333
APE_QDRANT__GRPC_PORT=6334
APE_QDRANT__PREFER_GRPC=false
APE_QDRANT__HTTPS=false
# APE_QDRANT__API_KEY=

# --- Object storage (document uploads) ---
# local = filesystem under LOCAL_ROOT; minio = S3-compatible (Docker stack)
APE_STORAGE__BACKEND=local
APE_STORAGE__LOCAL_ROOT=./storage

# ----------------------------------------------------------------------------
# Background jobs (Taskiq + Redis)
# ----------------------------------------------------------------------------
APE_JOBS__BACKEND=taskiq

# ----------------------------------------------------------------------------
# Knowledge ingestion limits
# ----------------------------------------------------------------------------
# Maximum upload size in bytes (default 50 MB); larger uploads return 413.
# APE_KNOWLEDGE__MAX_UPLOAD_BYTES=52428800

# ----------------------------------------------------------------------------
# Text chunking (knowledge ingestion)
# ----------------------------------------------------------------------------
# Strategy: recursive_character (only option today)
APE_CHUNKING__STRATEGY=recursive_character
APE_CHUNKING__CHUNK_SIZE=1000
APE_CHUNKING__CHUNK_OVERLAP=200

# ----------------------------------------------------------------------------
# Embeddings (retrieval Phase 1)
# ----------------------------------------------------------------------------
# Backend: hash | ollama | openai | gemini
# (any OpenAI-compatible host works via the openai backend + OPENAI_BASE_URL)
APE_EMBEDDING__BACKEND=hash
APE_EMBEDDING__MODEL=nomic-embed-text
APE_EMBEDDING__DIMENSIONS=384
APE_EMBEDDING__BATCH_SIZE=32
APE_EMBEDDING__OLLAMA_BASE_URL=http://localhost:11434
# APE_EMBEDDING__OPENAI_API_KEY=
# APE_EMBEDDING__OPENAI_BASE_URL=https://api.openai.com
# APE_EMBEDDING__GEMINI_API_KEY=
# APE_EMBEDDING__GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ----------------------------------------------------------------------------
# Vector store (retrieval Phase 2)
# ----------------------------------------------------------------------------
# Backend: qdrant | memory (memory is for tests only)
APE_VECTOR_STORE__BACKEND=qdrant
APE_VECTOR_STORE__COLLECTION_NAME=ape_chunks

# ----------------------------------------------------------------------------
# Retrieval pipeline
# ----------------------------------------------------------------------------
APE_RETRIEVAL__AUTO_EMBED=true
APE_RETRIEVAL__AUTO_INDEX=true
APE_RETRIEVAL__DEFAULT_TOP_K=10
APE_RETRIEVAL__EMBEDDING_SET_VERSION=1
APE_RETRIEVAL__FILTERABLE_METADATA_KEYS=source,tags

# ----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ----------------------------------------------------------------------------
APE_MINIO__ENDPOINT=localhost:9000
APE_MINIO__ACCESS_KEY=minioadmin
APE_MINIO__SECRET_KEY=minioadmin
APE_MINIO__SECURE=false
APE_MINIO__BUCKET=ape-artifacts
