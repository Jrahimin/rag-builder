# ===========================================================================
# AI Platform Engine (APE) - example environment file.
#
# Copy to `.env` and adjust as needed:
#     cp .env.example .env            (macOS/Linux)
#     Copy-Item .env.example .env     (Windows PowerShell)
#
# Two consumers read this file:
#   1. The application (Pydantic Settings) - all APE_* variables. Nested keys
#      use a double underscore, e.g. APE_DATABASE__HOST.
#   2. docker compose - the *_USER / *_PASSWORD / *_PORT variables used to
#      provision the service containers (and for ${VAR} interpolation).
#
# When running via docker compose, the backend container automatically points
# at the service hostnames (postgres, redis, qdrant, minio); the APE_*__HOST
# values below are used for LOCAL (venv) runs against localhost.
# ===========================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APE_APP__NAME=AI Platform Engine
# One of: development | testing | production
APE_APP__ENV=development
APE_APP__DEBUG=true
APE_APP__VERSION=0.1.0
APE_APP__API_V1_PREFIX=/api/v1

# ----------------------------------------------------------------------------
# Server (uvicorn)
# ----------------------------------------------------------------------------
APE_SERVER__HOST=0.0.0.0
APE_SERVER__PORT=8000
APE_SERVER__RELOAD=true
APE_SERVER__WORKERS=1

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
APE_LOGGING__LEVEL=INFO
# true  -> JSON logs (production / log aggregation)
# false -> colorized console logs (local development)
APE_LOGGING__RENDER_JSON=false

# ----------------------------------------------------------------------------
# CORS (comma-separated, or "*" for all)
# ----------------------------------------------------------------------------
APE_CORS__ALLOW_ORIGINS=*
APE_CORS__ALLOW_CREDENTIALS=true

# ----------------------------------------------------------------------------
# PostgreSQL
#   APE_DATABASE__* -> consumed by the application
#   POSTGRES_*      -> consumed by the postgres container & docker compose
# ----------------------------------------------------------------------------
APE_DATABASE__HOST=localhost
APE_DATABASE__PORT=5432
APE_DATABASE__USER=ape
APE_DATABASE__PASSWORD=ape
APE_DATABASE__NAME=ape
APE_DATABASE__ECHO=false
APE_DATABASE__POOL_SIZE=5
APE_DATABASE__MAX_OVERFLOW=10

POSTGRES_USER=ape
POSTGRES_PASSWORD=ape
POSTGRES_DB=ape
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
APE_REDIS__HOST=localhost
APE_REDIS__PORT=6379
APE_REDIS__DB=0
# APE_REDIS__PASSWORD=
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# Qdrant (vector database)
# ----------------------------------------------------------------------------
APE_QDRANT__HOST=localhost
APE_QDRANT__PORT=6333
APE_QDRANT__GRPC_PORT=6334
APE_QDRANT__PREFER_GRPC=false
APE_QDRANT__HTTPS=false
# APE_QDRANT__API_KEY=
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
#   APE_MINIO__* -> consumed by the application
#   MINIO_*      -> consumed by the minio container & docker compose
# ----------------------------------------------------------------------------
APE_MINIO__ENDPOINT=localhost:9000
APE_MINIO__ACCESS_KEY=minioadmin
APE_MINIO__SECRET_KEY=minioadmin
APE_MINIO__SECURE=false
APE_MINIO__BUCKET=ape-artifacts

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ape-artifacts
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----------------------------------------------------------------------------
# Backend (docker compose host port mapping)
# ----------------------------------------------------------------------------
BACKEND_PORT=8000
