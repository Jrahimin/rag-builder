# ===========================================================================
# AI Platform Engine (APE) - Docker / full-stack environment template.
#
# Copy to `.env.docker` at the repo root:
#     cp .env.docker.example .env.docker            (macOS/Linux)
#     Copy-Item .env.docker.example .env.docker     (Windows PowerShell)
#
# Used by docker compose for variable interpolation across the stack
# (backend today; frontend and other services in future).
#
# Start the stack:
#     docker compose --env-file .env.docker up --build
#
# For local backend development in a venv, use backend/.env instead.
# ===========================================================================

# ----------------------------------------------------------------------------
# Backend (application tuning — passed into the backend container)
# ----------------------------------------------------------------------------
APE_APP__ENV=development
APE_APP__DEBUG=true
APE_LOGGING__LEVEL=INFO
APE_LOGGING__RENDER_JSON=false

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
POSTGRES_USER=ape
POSTGRES_PASSWORD=ape
POSTGRES_DB=ape
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# Qdrant (vector database)
# ----------------------------------------------------------------------------
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ape-artifacts
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----------------------------------------------------------------------------
# Object storage (document uploads in backend container)
# ----------------------------------------------------------------------------
APE_STORAGE__BACKEND=minio
APE_STORAGE__LOCAL_ROOT=/data/storage
APE_JOBS__BACKEND=taskiq
APE_CHUNKING__CHUNK_SIZE=1000
APE_CHUNKING__CHUNK_OVERLAP=200

# ----------------------------------------------------------------------------
# Service host port mappings
# ----------------------------------------------------------------------------
BACKEND_PORT=8000
# FRONTEND_PORT=3000
