# ===========================================================================
# AI Platform Engine (APE) - Docker / full-stack environment template.
#
# Copy to `.env.docker` at the repo root:
#     cp .env.docker.example .env.docker            (macOS/Linux)
#     Copy-Item .env.docker.example .env.docker     (Windows PowerShell)
#
# Used by docker compose for variable interpolation across the full stack.
#
# Start the stack:
#     docker compose --env-file .env.docker up --build
#
# For local backend development in a venv, use backend/.env instead.
# ===========================================================================

# ----------------------------------------------------------------------------
# Backend (application tuning — passed into the backend container)
# ----------------------------------------------------------------------------
APE_APP__ENV=development
APE_APP__DEBUG=true
APE_RUNTIME__PROFILE=development
APE_LOGGING__LEVEL=INFO
APE_LOGGING__RENDER_JSON=false

# Authentication (required in production — generate unique random values)
# APE_AUTH__ENABLED=true
# APE_AUTH__ADMIN_API_KEY=replace-with-32-plus-byte-random-admin-key
# APE_AUTH__KEY_PEPPER=replace-with-32-plus-byte-random-pepper
# APE_AUTH__VERIFY_CACHE_BACKEND=redis
# APE_AUTH__RATE_LIMIT_ENABLED=true
# APE_AUTH__RATE_LIMIT_FAIL_OPEN=false

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
POSTGRES_USER=ape
POSTGRES_PASSWORD=ape
POSTGRES_DB=ape
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_PORT=6379
# Required and non-default in production.
REDIS_PASSWORD=

# ----------------------------------------------------------------------------
# Embedding and retrieval persistence contract
# Changing DIMENSIONS requires an Alembic migration plus full re-embedding.
# ----------------------------------------------------------------------------
APE_EMBEDDING__BACKEND=hash
APE_EMBEDDING__MODEL=nomic-embed-text
APE_EMBEDDING__DIMENSIONS=384
# Hosted profile:
# APE_EMBEDDING__OPENAI_API_KEY=replace-with-provider-key
# APE_EMBEDDING__OPENAI_BASE_URL=https://api.openai.com
# APE_LLM__BACKEND=openai
# APE_LLM__MODEL=gpt-4o-mini
# APE_LLM__OPENAI_API_KEY=replace-with-provider-key
# APE_LLM__OPENAI_BASE_URL=https://api.openai.com
# Private Ollama profile:
# APE_EMBEDDING__BACKEND=ollama
# APE_EMBEDDING__OLLAMA_BASE_URL=http://host.docker.internal:11434
# APE_LLM__BACKEND=ollama
# APE_LLM__MODEL=llama3.1
# APE_LLM__OLLAMA_BASE_URL=http://host.docker.internal:11434
APE_RETRIEVAL__STRATEGY=hybrid
APE_RETRIEVAL__HNSW_EF_SEARCH=100

# ----------------------------------------------------------------------------
# Upload malware scanning
# ----------------------------------------------------------------------------
# Local development may keep the explicit disabled provider. Production must
# point to a reachable ClamAV TCP service (the Compose stack does not bundle it).
APE_MALWARE_SCAN__BACKEND=disabled
APE_MALWARE_SCAN__HOST=clamav
APE_MALWARE_SCAN__PORT=3310
APE_MALWARE_SCAN__TIMEOUT_SECONDS=15

# ----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ape-artifacts
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----------------------------------------------------------------------------
# Object storage (document uploads in backend container)
# ----------------------------------------------------------------------------
APE_STORAGE__BACKEND=minio
APE_STORAGE__LOCAL_ROOT=/data/storage
APE_JOBS__BACKEND=taskiq
APE_CHUNKING__TARGET_TOKENS=250
APE_CHUNKING__MAX_TOKENS=400
APE_CHUNKING__OVERLAP_TOKENS=50

# ----------------------------------------------------------------------------
# Service host port mappings
# ----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
